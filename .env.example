# Hygraph CMS Configuration

# Project Settings → Endpoints → Copy High Performance Content API
NEXT_PUBLIC_HYGRAPH_CONTENT_ENDPOINT=https://eu-west-2.cdn.hygraph.com/content/cmoexv7zu00hf07w3197v1115/master
# Project Settings → Permanent Auth Tokens → Copy "Live Preview Token"
HYGRAPH_PREVIEW_TOKEN=your_live_preview_token_here
# Secret to validate preview requests - any secure random string
HYGRAPH_PREVIEW_SECRET=your_preview_secret_here

# For development to skip publishing, set to true to always use draft content
NEXT_PUBLIC_HYGRAPH_ALWAYS_DRAFT=true

# Optional: For production builds
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Sentry integration
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Vertex AI / Gemini Chat Advisor
GCP_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=europe-west3

# Hygraph MCP Server Token (for local development with Claude Code)
HYGRAPH_MCP_TOKEN=your_hygraph_mcp_token_here
