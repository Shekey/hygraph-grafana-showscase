# Hygraph CMS Configuration

# Project Settings → Endpoints → Copy High Performance Content API 
NEXT_PUBLIC_HYGRAPH_CONTENT_ENDPOINT=https://eu-central-1-staging.cdn.hygraph.com/content/YOUR_PROJECT_ID/master
# Project Settings → Permanent Auth Tokens → Copy "Live Preview Token"
HYGRAPH_PREVIEW_TOKEN=your_preview_token_here
# Secret to validate preview requests - any secure random string
HYGRAPH_PREVIEW_SECRET=your_preview_secret_here

# For development to skip publishing, set to true to always use draft content
NEXT_PUBLIC_HYGRAPH_ALWAYS_DRAFT=true

# Optional: For production builds
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Sentry integration
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Vertex AI / Gemini Chat Advisor
# Your GCP project ID (same project where Cloud Run is deployed)
GCP_PROJECT_ID=your-gcp-project-id
# Vertex AI region — must match where gemini-2.0-flash is available
VERTEX_AI_LOCATION=europe-west3

# OpenTelemetry Configuration (Local Development)
# Service name for identifying this app in metrics/traces
OTEL_SERVICE_NAME=hygike
# OTLP collector endpoint (Docker Compose runs at localhost:4328)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4328

# Production (Cloud Run) automatically uses:
# - GCP Cloud Monitoring for metrics
# - GCP Cloud Trace for traces
# - Application Default Credentials (ADC) for authentication
# No additional env vars needed in production!